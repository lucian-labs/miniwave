#!/bin/bash
# PocketWave X starter — waits for VT readiness then launches X
# Used by pocketwave-x.service

# Wait for /dev/tty1 to be usable
for i in $(seq 1 10); do
    if [ -c /dev/tty1 ]; then
        break
    fi
    sleep 1
done

# Switch to VT1 and wait
chvt 1 2>/dev/null
sleep 2

exec /usr/bin/xinit /home/chip/.xinitrc -- :0 vt1 -nolisten tcp
